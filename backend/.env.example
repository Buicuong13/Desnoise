# Copy this file to .env and replace placeholders before running locally.

APP_NAME=denoise-backend
APP_ENV=development
DEBUG=true

SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

DATABASE_URL=postgresql+psycopg2://denoise:denoise@localhost:5433/denoise_db

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Set true if you want denoise tasks to run inside the API process without a Celery worker.
CELERY_TASK_ALWAYS_EAGER=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAX_UPLOAD_SIZE_MB=20
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/tiff,image/bmp
LOCAL_STORAGE_DIR=storage_data

DENOISING_IMAGE_SIZE=256
DENOISING_BATCH_SIZE=8
DENOISING_WEIGHTS_PATH=

TESSERACT_CMD=tesseract
TESSERACT_LANG=vie+eng

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_QWEN_MODEL=qwen/qwen-2.5-7b-instruct:free
SUSPICIOUS_CONFIDENCE_THRESHOLD=70.0

VIEWER_MAX_IMAGES=10
VIEWER_MAX_WORKSPACES=2

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
